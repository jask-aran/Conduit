{
  "name": "@conduit/web",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "vite build && node scripts/check-bundle.mjs",
    "dev": "vite --host 0.0.0.0",
    "dev:server": "node --watch src/server.js",
    "start": "node src/server.js",
    "test": "node --test test/*.test.js",
    "test:browser": "playwright test",
    "test:browser:headed": "playwright test --headed",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "0.80.6",
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@fontsource-variable/geist": "^5.2.9",
    "@kobalte/core": "0.13.12",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "dompurify": "3.4.12",
    "express": "^4.22.2",
    "katex": "^0.16.27",
    "lucide-solid": "1.25.0",
    "marked": "18.0.6",
    "marked-katex-extension": "5.1.10",
    "solid-js": "1.9.14",
    "solid-sonner": "0.3.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "tailwindcss": "^4.3.2",
    "typescript": "7.0.2",
    "vite": "^6.4.3",
    "vite-plugin-solid": "2.11.13"
  }
}
