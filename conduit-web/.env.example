# Development-only absolute override for Conduit's bundled Pi 0.80.6 executable.
# CONDUIT_PI_COMMAND=/absolute/path/to/pi
# Optional absolute host Pi override; otherwise Conduit detects `pi` through the login shell.
# CONDUIT_NATIVE_PI_COMMAND=/home/user/.local/bin/pi
# Optional Native Pi home override; otherwise Conduit honors the login shell's
# PI_CODING_AGENT_DIR or uses $HOME/.pi/agent.
# CONDUIT_NATIVE_PI_AGENT_DIR=/home/user/.pi/agent
CONDUIT_HOST=127.0.0.1
CONDUIT_PORT=4310
CONDUIT_FILES_ROOT=../data/chat/files
CONDUIT_CATALOG_FILE=../data/conduit.json
CONDUIT_SESSION_REGISTRY_FILE=../data/sessions.json
CONDUIT_PI_AGENT_DIR=../data/pi
# Default profile path when data/preferences.json is absent; all templates/*/template.json are discovered.
CONDUIT_PI_TEMPLATE=../templates/chat/template.json
# Optional override for the templates root (defaults to ../templates).
# CONDUIT_TEMPLATES_ROOT=../templates
# Comma-separated absolute roots that linked workspaces may use (default: $HOME, repo, files root).
# CONDUIT_WORKSPACE_ALLOWLIST=~,/workspaces
# Optional path for default profile and other app preferences.
# CONDUIT_PREFERENCES_FILE=../data/preferences.json
# Max warm Pi processes kept resident (Settings → Runtime can override via data/runtime.json).
CONDUIT_MAX_LIVE_PROCESSES=12
# Max concurrent agent loops / generations (extra prompts return generation_limit).
CONDUIT_MAX_GENERATING_PROCESSES=2
# Stop unattached idle Pi processes after this many milliseconds (default 2 minutes).
CONDUIT_IDLE_PROCESS_TTL_MS=120000
# Optional path for persisted runtime policy (warm pool / generating cap / idle TTL).
# CONDUIT_RUNTIME_SETTINGS_FILE=../data/runtime.json
# Auth: scrypt password and stored sessions live in data/auth.json (mode 0600).
# Provision with `node scripts/conduit-auth.mjs set-password` from the repo root.
# CONDUIT_AUTH_FILE=../data/auth.json
# Permit a non-loopback bind (0.0.0.0 or tunnel forward) without a configured
# password. Development-only override; never enable this on a reachable host.
# CONDUIT_ALLOW_INSECURE=1
# Experimental ordinary-prompt continuation for stopped partial responses.
ENABLE_PARTIAL_CONTINUE=true
# Build-time bundle budgets in gzip bytes, enforced by `npm run build`.
# CONDUIT_BUDGET_INITIAL_JS_GZIP=180000
# CONDUIT_BUDGET_INITIAL_CSS_GZIP=80000
# CONDUIT_BUDGET_LAZY_JS_GZIP=300000
