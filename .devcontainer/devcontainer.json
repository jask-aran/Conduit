{
  "name": "Conduit",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false,
      "installOhMyZsh": false,
      "upgradePackages": false
    }
  },
  "forwardPorts": [4310],
  "portsAttributes": {
    "4310": {
      "label": "Conduit",
      "onAutoForward": "openBrowser",
      "protocol": "http"
    }
  },
  "containerEnv": {
    "CONDUIT_HOST": "0.0.0.0",
    "CONDUIT_PORT": "4310",
    "CONDUIT_FILES_ROOT": "/workspaces/Conduit/data/chat/files",
    "CONDUIT_CATALOG_FILE": "/workspaces/Conduit/data/conduit.json",
    "CONDUIT_PI_AGENT_DIR": "/workspaces/Conduit/data/pi",
    "CONDUIT_PI_TEMPLATE": "/workspaces/Conduit/templates/chat/template.json"
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "postStartCommand": "bash .devcontainer/start-conduit.sh",
  "remoteUser": "node"
}
